# Supabase Configuration
SUPABASE_URL=FILL_HERE
SUPABASE_ANON_KEY=FILL_HERE
SUPABASE_SERVICE_ROLE_KEY=FILL_HERE

# Google Gemini API Configuration (Free tier)
GOOGLE_API_KEY=FILL_HERE

# Redis Configuration (for Bull queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Server Configuration
PORT=3000
NODE_ENV=development

# LLM Configuration
# Options: 'ollama' (local), 'gemini' (cloud)
LLM_PROVIDER=ollama

# Ollama (local LLM running on home PC via Cloudflare Tunnel)
# Set this to your Cloudflare Tunnel URL for remote access, or http://localhost:11434 for local
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
